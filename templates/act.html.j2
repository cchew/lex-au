<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ meta.name }}</title>
  <style>
    body { font-family: Georgia, serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    .container { margin-top: 2rem; }
    .division { margin-left: 1rem; }
    .subdivision { margin-left: 2rem; }
    .section { margin-top: 1rem; padding-left: 1.5rem; }
    .section-num { font-weight: bold; }
  </style>
</head>
<body>
<p><a href="/">← All Acts</a></p>
<h1>{{ meta.name }}</h1>
<p>Compilation #{{ meta.comp_num }} | Effective {{ meta.effective_date }}</p>
<p>FRBR Work URI: <code>{{ meta.frbr_work_uri }}</code></p>

{% set container_labels = {"chapter": "Chapter", "part": "Part", "division": "Division", "subDivision": "Subdivision"} %}

{% macro render_node(node) %}
{% if node.tag == "section" %}
<div class="section" id="{{ node.eid }}">
  <span class="section-num">{{ node.num }}</span>{% if node.heading %} {{ node.heading }}{% endif %}
  {% for p in node.paragraphs %}<p>{{ p }}</p>{% endfor %}
</div>
{% else %}
<div class="container {{ node.tag|lower }}" id="{{ node.eid }}">
  <h2>{{ container_labels.get(node.tag, node.tag) }} {{ node.num }}{% if node.heading %} — {{ node.heading }}{% endif %}</h2>
  {% for p in node.paragraphs %}<p>{{ p }}</p>{% endfor %}
  {% for child in node.children %}{{ render_node(child) }}{% endfor %}
</div>
{% endif %}
{% endmacro %}

{% for node in body %}{{ render_node(node) }}{% endfor %}
</body>
</html>
